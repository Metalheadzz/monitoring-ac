  {
    "id": "func-build-query",
    "type": "function",
    "z": "tab-ac-monitor",
    "name": "Build Flux Query",
    "func": "var token  = env.get('INFLUXDB_TOKEN');\nvar url    = env.get('INFLUXDB_URL') || 'http://host.docker.internal:8087';\nvar org    = env.get('INFLUXDB_ORG')  || 'myorg';\nvar bucket = env.get('INFLUXDB_BUCKET') || 'mybucket';\n\nvar query = 'from(bucket:\"' + bucket + '\")\\n' +\n  '  |> range(start: -1h)\\n' +\n  '  |> filter(fn: (r) => r._measurement == \"suhu_ruangan\")\\n' +\n  '  |> filter(fn: (r) => r._field == \"suhu\")\\n' +\n  '  |> aggregateWindow(every: 1m, fn: mean, createEmpty: false)\\n' +\n  '  |> yield(name: \"mean\")';\n\nmsg.url     = url + '/api/v2/query?org=' + org;\nmsg.headers = {\n  'Authorization' : 'Token ' + token,\n  'Content-Type'  : 'application/vnd.flux',\n  'Accept'        : 'application/csv'\n};\nmsg.payload = query;\nmsg.method  = 'POST';\n\nreturn msg;",
    "outputs": 1,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 340,
    "y": 540,
    "wires": [["http-influx-query"]]
  },
  {
    "id": "http-influx-query",
    "type": "http request",
    "z": "tab-ac-monitor",
    "name": "Query InfluxDB",
    "method": "POST",
    "ret": "txt",
    "paytoqs": "ignore",
    "url": "",
    "tls": "",
    "persist": false,
    "proxy": "",
    "insecureHTTPParser": false,
    "authType": "",
    "senderr": false,
    "headers": [],
    "x": 540,
    "y": 540,
    "wires": [["func-parse-csv"]]
  },
  {
    "id": "func-parse-csv",
    "type": "function",
    "z": "tab-ac-monitor",
    "name": "Parse CSV InfluxDB",
    "func": "var csv = msg.payload;\nif (!csv || typeof csv !== 'string') {\n  node.warn('Tidak ada response dari InfluxDB');\n  return null;\n}\n\n// Filter baris valid (bukan annotation #, bukan kosong)\nvar lines = csv.split('\\n').filter(function(l) {\n  return l.trim() && !l.startsWith('#');\n});\n\nif (lines.length < 2) {\n  node.warn('Tidak ada data history (bucket mungkin masih kosong)');\n  return null;\n}\n\nvar headers   = lines[0].split(',');\nvar timeIdx   = headers.indexOf('_time');\nvar valueIdx  = headers.indexOf('_value');\n\nif (timeIdx < 0 || valueIdx < 0) {\n  node.warn('Format CSV tidak dikenali, cek Flux query');\n  return null;\n}\n\nvar dataPoints = [];\nfor (var i = 1; i < lines.length; i++) {\n  var cols = lines[i].split(',');\n  if (cols.length > Math.max(timeIdx, valueIdx)) {\n    var val = parseFloat(cols[valueIdx]);\n    if (!isNaN(val)) {\n      dataPoints.push({\n        x: new Date(cols[timeIdx]).getTime(),\n        y: parseFloat(val.toFixed(1))\n      });\n    }\n  }\n}\n\nif (dataPoints.length === 0) {\n  node.warn('Data points kosong setelah parsing');\n  return null;\n}\n\nmsg.payload = [{\n  series: ['Suhu Rata-rata (°C)'],\n  data   : [dataPoints],\n  labels : ['']\n}];\n\nreturn msg;",
    "outputs": 1,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 720,
    "y": 540,
    "wires": [["chart-history"]]
  },
