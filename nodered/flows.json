  {
    "id": "notif-ac",
    "type": "function",
    "z": "tab-ac-monitor",
    "name": "Format Notifikasi",
    "func": "if (msg.payload === 'ON') {\n  msg.payload = 'Perintah AC ON berhasil dikirim!';\n} else {\n  msg.payload = 'Perintah AC OFF berhasil dikirim!';\n}\nmsg.topic = 'Kontrol AC';\nreturn msg;",
    "outputs": 1,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
