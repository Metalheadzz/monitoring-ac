    "type": "mqtt in",
    "z": "tab-ac-monitor",
    "name": "Sensor Suhu",
    "topic": "sensor/suhu",
    "qos": "0",
    "datatype": "json",
    "broker": "mqtt-broker-cfg",
    "nl": false,
    "rap": false,
    "rh": 0,
    "inputs": 0,
    "x": 120,
    "y": 120,
    "wires": [["func-parse-data"]]
  },
  {
    "id": "func-parse-data",
    "type": "function",
    "z": "tab-ac-monitor",
    "name": "Parse Data Sensor",
    "func": "var suhu = msg.payload.suhu;\nvar statusAC = msg.payload.status_ac;\n\n// Output 1: nilai suhu untuk gauge dan chart realtime\nvar msgSuhu = { payload: suhu, topic: 'suhu' };\n\n// Output 2: status AC untuk text display\nvar msgStatus = {\n  payload: statusAC === 'ON' ? 'AC  MENYALA' : 'AC  MATI',\n  topic: 'status_ac'\n};\n\nreturn [msgSuhu, msgStatus];",
    "outputs": 2,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 320,
    "y": 120,
    "wires": [
      ["gauge-suhu", "chart-realtime", "text-suhu-nilai"],
      ["text-status-ac"]
    ]
  },
